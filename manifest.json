{
  "manifest_version": 3,
  "name": "ChatGPT Batch Tools",
  "version": "1.1.0",
  "description": "Batch delete ChatGPT conversations or move them into a project",
  "permissions": ["declarativeContent"],
  "host_permissions": ["https://chatgpt.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
